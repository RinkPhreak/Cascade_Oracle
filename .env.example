# System
TZ=Europe/Moscow
# 32-byte AES-256-GCM key (base64 or hex)
APP_ENCRYPTION_KEY=your_32_byte_aes_key_here_exactly_32!

# Database
POSTGRES_USER=cascade_user
POSTGRES_PASSWORD=cascade_secure_password
POSTGRES_DB=cascade
POSTGRES_DSN=postgres://cascade_user:cascade_secure_password@postgres:5432/cascade?sslmode=disable

# Redis
REDIS_ADDR=redis:6379

# Telegram MTProto (from my.telegram.org)
TG_APP_ID=123456
TG_APP_HASH=your_telegram_app_hash

# Operator Auth
ADMIN_LOGIN=admin
# bcrypt hash (cost=12) of the operator's password
ADMIN_PASSWORD_HASH='$2a$12$eImiTXuWVxfM37uY4JANjQ=='
# RSA Keys for JWT (PEM format strings, base64 encoded for env vars or multiline)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Logic & Limits
MIN_ACTIVE_ACCOUNTS_TG=3
MIN_ACTIVE_ACCOUNTS_WA=3
